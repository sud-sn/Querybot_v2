# ── QueryBot environment variables ────────────────────────────────────────────
# These are NO LONGER REQUIRED once you have run the first-time setup in the
# admin UI at http://YOUR-VM-IP:8000/admin
#
# They are provided here ONLY for reference / initial migration.
# The bot reads all credentials from the encrypted SQLite store at runtime.

# ── Key file location (optional override) ─────────────────────────────────────
# Default: ~/.querybot_key  (generated automatically on first run)
# QUERYBOT_KEY_FILE=/custom/path/.querybot_key

# ── Database file location (optional override) ────────────────────────────────
# Default: ./data/querybot.db
# DB_PATH=/var/lib/querybot/querybot.db
