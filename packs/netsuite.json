{
  "pack_id": "netsuite",
  "erp_name": "Oracle NetSuite",
  "version": 1,
  "status": "complete",
  "description": "NetSuite SuiteAnalytics/SuiteQL table and field dictionary: transaction/transactionline, customer/vendor/entity, item, account, subsidiary, and the lowercase-concatenated field-naming convention (tranid, trandate, entityid). Includes the custbody_/custentity_/custitem_/custcol_/custrecord_ custom-field prefixes.",
  "column_dict": {
    "TRANID":              {"label": "Transaction Number",              "synonyms": ["transaction number", "document number", "order number", "invoice number"]},
    "TRANDATE":            {"label": "Transaction Date",                "synonyms": ["transaction date", "document date"]},
    "ENTITY":              {"label": "Customer/Vendor",                 "synonyms": ["customer", "vendor", "entity"]},
    "ENTITYID":            {"label": "Entity ID",                       "synonyms": ["customer id", "vendor id", "entity code"]},
    "ITEM":                {"label": "Item",                            "synonyms": ["item", "product"]},
    "ITEMID":              {"label": "Item Number",                     "synonyms": ["item number", "sku", "product code"]},
    "QUANTITY":            {"label": "Quantity",                        "synonyms": ["quantity", "qty"]},
    "RATE":                {"label": "Unit Rate",                       "synonyms": ["unit price", "rate", "price"]},
    "AMOUNT":              {"label": "Amount",                          "synonyms": ["amount", "line amount"]},
    "NETAMOUNT":           {"label": "Net Amount",                      "synonyms": ["net amount"]},
    "GROSSAMOUNT":         {"label": "Gross Amount",                    "synonyms": ["gross amount"]},
    "FOREIGNTOTAL":        {"label": "Total Amount (Transaction Currency)", "synonyms": ["total amount", "transaction total"]},
    "TOTAL":               {"label": "Total Amount",                    "synonyms": ["total", "grand total"]},
    "TAXAMOUNT":           {"label": "Tax Amount",                      "synonyms": ["tax amount", "sales tax"]},
    "TAXTOTAL":            {"label": "Total Tax",                       "synonyms": ["total tax"]},
    "EXCHANGERATE":        {"label": "Exchange Rate",                   "synonyms": ["exchange rate", "currency rate"]},
    "CURRENCY":            {"label": "Currency",                        "synonyms": ["currency"]},
    "SUBSIDIARY":          {"label": "Subsidiary",                      "synonyms": ["subsidiary", "company", "legal entity"]},
    "DEPARTMENT":          {"label": "Department",                      "synonyms": ["department"]},
    "CLASS":               {"label": "Class",                           "synonyms": ["class", "business unit"]},
    "LOCATION":            {"label": "Location",                        "synonyms": ["location", "warehouse"]},
    "STATUS":              {"label": "Status",                          "synonyms": ["status", "transaction status"]},
    "TYPE":                {"label": "Transaction Type",                "synonyms": ["transaction type", "record type"]},
    "DUEDATE":             {"label": "Due Date",                        "synonyms": ["due date", "payment due date"]},
    "SHIPDATE":            {"label": "Ship Date",                       "synonyms": ["ship date", "shipping date"]},
    "CLOSEDATE":           {"label": "Close Date",                      "synonyms": ["close date", "closed date"]},
    "CREATEDDATE":         {"label": "Created Date",                    "synonyms": ["created date", "creation date"]},
    "LASTMODIFIEDDATE":    {"label": "Last Modified Date",              "synonyms": ["last modified date", "updated date"]},
    "TERMS":               {"label": "Payment Terms",                   "synonyms": ["payment terms", "terms"]},
    "MEMO":                {"label": "Memo",                            "synonyms": ["memo", "notes"]},
    "PONUMBER":            {"label": "PO Number",                       "synonyms": ["purchase order number", "po number"]},
    "OTHERREFNUM":         {"label": "Reference Number",                "synonyms": ["reference number", "other reference"]},
    "INTERNALID":          {"label": "Internal ID",                     "synonyms": ["internal id", "record id"]},
    "EXTERNALID":          {"label": "External ID",                     "synonyms": ["external id"]},
    "ACCOUNTNUMBER":       {"label": "Account Number",                  "synonyms": ["account number", "gl account number"]},
    "COMPANYNAME":         {"label": "Company Name",                    "synonyms": ["company name"]},
    "QUANTITYONHAND":      {"label": "Quantity On Hand",                "synonyms": ["on hand quantity", "stock on hand"]},
    "QUANTITYAVAILABLE":   {"label": "Quantity Available",              "synonyms": ["available quantity", "available to sell"]},
    "QUANTITYCOMMITTED":   {"label": "Quantity Committed",              "synonyms": ["committed quantity", "allocated quantity"]},
    "QUANTITYBACKORDERED": {"label": "Quantity Backordered",            "synonyms": ["backordered quantity", "backorder quantity"]}
  },
  "table_dict": {
    "TRANSACTION":                  {"label": "Transaction Header",              "synonyms": ["transactions", "orders", "invoices", "bills"], "type": "fact"},
    "TRANSACTIONLINE":              {"label": "Transaction Line",                "synonyms": ["transaction lines", "order lines", "invoice lines"], "type": "fact"},
    "TRANSACTIONACCOUNTINGLINE":    {"label": "Transaction GL Impact Line",      "synonyms": ["gl impact", "accounting lines"], "type": "fact"},
    "CUSTOMER":                     {"label": "Customer Master",                 "synonyms": ["customers", "customer master"], "type": "dimension"},
    "VENDOR":                       {"label": "Vendor Master",                   "synonyms": ["vendors", "suppliers"], "type": "dimension"},
    "ENTITY":                       {"label": "Entity Master",                   "synonyms": ["entities", "customers and vendors"], "type": "dimension"},
    "ITEM":                         {"label": "Item Master",                     "synonyms": ["items", "products", "item master"], "type": "dimension"},
    "ACCOUNT":                      {"label": "Chart of Accounts",               "synonyms": ["accounts", "gl accounts", "chart of accounts"], "type": "dimension"},
    "SUBSIDIARY":                   {"label": "Subsidiary",                      "synonyms": ["subsidiaries", "companies"], "type": "dimension"},
    "DEPARTMENT":                   {"label": "Department",                      "synonyms": ["departments"], "type": "dimension"},
    "CLASSIFICATION":               {"label": "Class",                           "synonyms": ["classes", "business units"], "type": "dimension"},
    "LOCATION":                     {"label": "Location",                        "synonyms": ["locations", "warehouses"], "type": "dimension"},
    "ACCOUNTINGPERIOD":             {"label": "Accounting Period",               "synonyms": ["fiscal periods", "accounting periods"], "type": "dimension"}
  },
  "abbreviations": {
    "CUSTBODY":   "custom transaction field",
    "CUSTENTITY": "custom entity field",
    "CUSTITEM":   "custom item field",
    "CUSTCOL":    "custom line field",
    "CUSTRECORD": "custom record field"
  },
  "direct_aliases": {
    "TRANID":              ["transaction number", "document number"],
    "ITEMID":              ["item number", "item id", "sku"],
    "QUANTITYONHAND":      ["quantity on hand", "on hand quantity"],
    "QUANTITYAVAILABLE":   ["quantity available", "available quantity"],
    "QUANTITYCOMMITTED":   ["quantity committed", "committed quantity"],
    "QUANTITYBACKORDERED": ["quantity backordered", "backordered quantity"],
    "FOREIGNTOTAL":        ["transaction total"],
    "PONUMBER":            ["po number", "purchase order number"]
  },
  "raw_identifier_codes": [
    "TRANID", "ENTITY", "ENTITYID", "ITEM", "ITEMID", "SUBSIDIARY",
    "DEPARTMENT", "CLASS", "LOCATION", "INTERNALID", "EXTERNALID",
    "ACCOUNTNUMBER", "TERMS", "PONUMBER", "OTHERREFNUM", "STATUS", "TYPE"
  ],
  "raw_measure_codes": [
    "QUANTITY", "RATE", "AMOUNT", "NETAMOUNT", "GROSSAMOUNT", "FOREIGNTOTAL",
    "TOTAL", "TAXAMOUNT", "TAXTOTAL", "EXCHANGERATE", "QUANTITYONHAND",
    "QUANTITYAVAILABLE", "QUANTITYCOMMITTED", "QUANTITYBACKORDERED"
  ],
  "date_role_patterns": [
    {"pattern": "^TRANDATE$",        "role": "accounting_date"},
    {"pattern": "^DUEDATE$",         "role": "due_date"},
    {"pattern": "^SHIPDATE$",        "role": "delivery_date"},
    {"pattern": "^CREATEDDATE$",     "role": "creation_date"},
    {"pattern": "^LASTMODIFIEDDATE$","role": "modified_date"}
  ]
}
