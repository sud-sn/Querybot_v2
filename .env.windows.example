# QueryBot application database. Percent-encode special characters in passwords.
DATABASE_URL=postgresql://querybot:CHANGE_ME@127.0.0.1:5432/querybot

# Qdrant REST endpoint. Keep it private to the VM unless using Qdrant Cloud.
QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=
QUERYBOT_RERANK=true

# Public HTTPS address used in registration links and callbacks.
PORTAL_BASE_URL=https://querybot.example.com

# Use three independently generated values in production.
SESSION_SECRET=CHANGE_ME
PORTAL_SESSION_SECRET=CHANGE_ME
ADMIN_SESSION_SECRET=CHANGE_ME
PII_PSEUDONYM_SECRET=CHANGE_ME_TO_A_SEPARATE_RANDOM_SECRET

# Back up this file. Losing it prevents decryption of stored credentials.
QUERYBOT_KEY_FILE=C:/QueryBot/secrets/.querybot_key

LLM_AUDIT_RETENTION_DAYS=30

# SQLite fallback only. DATABASE_URL takes precedence.
# DB_PATH=C:/QueryBot/data/querybot.db
